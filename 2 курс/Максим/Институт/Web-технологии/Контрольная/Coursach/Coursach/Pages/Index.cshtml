                            <img src="data:image;base64,@System.Convert.ToBase64String(Model.FavoriteWathes[0].Bytes)" height="150" />
                            <div class="card-body">
                                <h5 class="card-title">@Html.DisplayFor(model => model.FavoriteWathes[0].ModelName)</h5>
                            </div>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item">@Html.DisplayFor(model => model.FavoriteWathes[0].Brand.Name)</li>
                                <li class="list-group-item">@Html.DisplayFor(model => model.FavoriteWathes[0].Price)</li>
                            </ul>
                            <a class="btn btn-info" asp-page="./WatchDetail" asp-route-id="@Model.FavoriteWathes[0].Id">Детали</a>
                        </div>
